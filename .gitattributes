# Enforce LF in-repo to reduce churn across Windows/macOS/Linux
* text=auto eol=lf

# Common text formats
*.md  text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
*.sh  text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
