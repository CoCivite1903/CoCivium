{
  "state": "COEX_VERIFIED",
  "utc": "20260325T213208Z",
  "scope": "COSOURCENET_REGISTRY",
  "sensitivity": "S1",
  "source": "clipboard_safe_metadata_only",
  "write_root": "CoCivite1903/CoCivium",
  "policy": [
    "NO_PASSWORDS",
    "NO_PAT_VALUES",
    "NO_2FA_SECRETS",
    "METADATA_ONLY",
    "USE_BITWARDEN_AS_SECRET_STORE"
  ],
  "entries": [
    {
      "source_id": "__TITLE_COSOURCENET_REGISTRY_BOOTSTRAP_V1",
      "label": "# TITLE=COSOURCENET_REGISTRY_BOOTSTRAP_V1",
      "email": "",
      "username": "= $e.username",
      "provider": "sourcehut",
      "group": "CoSourceNet",
      "roles": [
        "s         = @($e.roles)"
      ],
      "status": "= $e.status",
      "attachment": "unknown",
      "write_budget": "unknown",
      "pat_present": "_present   = $e.pat_present",
      "twofa": "unknown",
      "notes": [
        "$ErrorActionPreference='Stop'; Set-StrictMode -Version Latest",
        "$Repo='CoCivite1903/CoCivium'",
        "$Branch='main'",
        "$Utc=(Get-Date).ToUniversalTime().ToString('yyyyMMddTHHmmssZ')",
        "$Today=(Get-Date).ToUniversalTime().ToString('yyyy-MM-dd')",
        "function Set-CoExArtifact {",
        "param(",
        "[Parameter(Mandatory)] [string] $Path,",
        "[Parameter(Mandatory)] $Object,",
        "[Parameter(Mandatory)] [string] $Message",
        ")",
        "$Json = ($Object | ConvertTo-Json -Depth 50) + \"`n\"",
        "$B64  = [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes($Json))",
        "$sha=$null",
        "try {",
        "$r = gh api \"repos/$Repo/contents/$Path`?ref=$Branch\" 2>$null | ConvertFrom-Json",
        "$sha = $r.sha",
        "} catch {}",
        "$args=@(",
        "\"repos/$Repo/contents/$Path\",",
        "\"-X\",\"PUT\",",
        "\"-H\",\"Accept: application/vnd.github+json\",",
        "\"-f\",\"message=$Message\",",
        "\"-f\",\"content=$B64\",",
        "\"-f\",\"branch=$Branch\"",
        "if($sha){ $args += @('-f',\"sha=$sha\") }",
        "$rawResponse = gh api @args 2>&1",
        "if ($LASTEXITCODE -ne 0) { throw \"GH_PUT_FAILED :: $rawResponse\" }",
        "$put = $rawResponse | ConvertFrom-Json",
        "if (-not $put.commit -or -not $put.commit.sha) {",
        "throw \"NO_COMMIT_SHA_IN_RESPONSE :: $rawResponse\"",
        "}",
        "$raw = \"https://raw.githubusercontent.com/$Repo/$($put.commit.sha)/$Path\"",
        "for($i=1;$i -le 10;$i++){",
        "try{",
        "$r=Invoke-WebRequest -UseBasicParsing -Uri $raw -ErrorAction Stop",
        "if($r.StatusCode -eq 200 -and $r.Content.Trim() -eq $Json.Trim()){",
        "return $raw",
        "Start-Sleep 2",
        "throw \"RAW_VERIFY_FAILED :: $raw\"",
        "# ---- INPUT ----",
        "# Expected source = safe clipboard text only: names, usernames/emails, notes, no passwords/tokens/codes",
        "$clip = Get-Clipboard -Raw",
        "if([string]::IsNullOrWhiteSpace($clip)){",
        "throw \"CLIPBOARD_EMPTY :: copy safe Bitwarden metadata list first (names/usernames/notes only)\"",
        "$lines = $clip -split \"`r?`n\" | ForEach-Object { $_.Trim() } | Where-Object { $_ }",
        "# ---- PARSE ----",
        "$entries = New-Object System.Collections.Generic.List[object]",
        "$current = $null",
        "function New-Entry {",
        "param([string]$Name)",
        "[ordered]@{",
        "source_id = ''",
        "label = $Name",
        "provider = 'unknown'",
        "group = 'CoSourceNet'",
        "attachment = 'unknown'",
        "write_budget = 'unknown'",
        "twofa = 'unknown'",
        "notes = @()",
        "sensitivity = 'S1'",
        "foreach($line in $lines){",
        "if($line -match '^\\.(node|source)\\s' -or $line -match '^\\.node' -or $line -match '^node'){",
        "if($current){ $entries.Add($current) }",
        "$current = New-Entry -Name $line",
        "$safeId = ($line -replace '[^A-Za-z0-9_.@-]','_')",
        "$current.source_id = $safeId",
        "if($line -match '@'){ $current.email = ($line -split '\\s+') | Where-Object { $_ -match '@' } | Select-Object -First 1 }",
        "continue",
        "if(-not $current){",
        "# start a generic entry when clipboard format is less structured",
        "if($line -match '^(Account Username and Email|Username|Email)\\s*:?\\s*(.+)$'){",
        "$value = $Matches[2].Trim()",
        "if($value -match '@'){ $current.email = $value }",
        "else { $current.username = $value }",
        "if($line -match '^ROLE\\s*:?\\s*(.+)$'){",
        "$current.roles = ($Matches[1] -split '\\||,') | ForEach-Object { $_.Trim() } | Where-Object { $_ }",
        "if($line -match '^STATUS\\s*:?\\s*(.+)$'){",
        "$current.status = $Matches[1].Trim()",
        "if($line -match '^PAT\\s*:?\\s*(.+)$'){",
        "$current.pat_present = $Matches[1].Trim()",
        "if($line -match '^2FA\\s*:?\\s*(.+)$'){",
        "$current.twofa = $Matches[1].Trim()",
        "if($line -match 'codeberg\\.org|github\\.com|gitlab\\.com|bitbucket|sourcehut'){",
        "if($line -match 'codeberg\\.org'){ $current.provider = 'codeberg' }",
        "elseif($line -match 'github\\.com'){ $current.provider = 'github' }",
        "elseif($line -match 'gitlab\\.com'){ $current.provider = 'gitlab' }",
        "elseif($line -match 'bitbucket'){ $current.provider = 'bitbucket' }",
        "elseif($line -match 'sourcehut'){ $current.provider = 'sourcehut' }",
        "$current.notes += $line",
        "# normalize",
        "$normalized = @()",
        "foreach($e in $entries){",
        "if([string]::IsNullOrWhiteSpace($e.source_id)){ continue }",
        "if([string]::IsNullOrWhiteSpace($e.attachment)){",
        "if($e.status -match 'ACTIVE'){ $e.attachment='candidate' } else { $e.attachment='unknown' }",
        "$normalized += [ordered]@{",
        "source_id     = $e.source_id",
        "label         = $e.label",
        "provider      = $e.provider",
        "group         = $e.group",
        "attachment    = $e.attachment",
        "write_budget  = $e.write_budget",
        "twofa         = $e.twofa",
        "notes         = @($e.notes | Select-Object -Unique)",
        "sensitivity   = 'S1'",
        "if(@($normalized).Count -eq 0){",
        "throw \"NO_SAFE_ENTRIES_PARSED :: clipboard content did not yield any metadata entries\"",
        "# ---- ARTIFACTS ----",
        "$registry = [ordered]@{",
        "state='COEX_VERIFIED'",
        "utc=$Utc",
        "scope='COSOURCENET_REGISTRY'",
        "sensitivity='S1'",
        "source='clipboard_safe_metadata_only'",
        "write_root=$Repo",
        "policy=@(",
        "'NO_PASSWORDS',",
        "'NO_PAT_VALUES',",
        "'NO_2FA_SECRETS',",
        "'METADATA_ONLY',",
        "'USE_BITWARDEN_AS_SECRET_STORE'",
        "entries=$normalized",
        "$inbox = [ordered]@{",
        "scope='COSOURCENET_INBOX'",
        "items=@(",
        "@{",
        "id='TASK_ATTACH_AND_CLASSIFY_NEW_COSOURCES'",
        "type='TASK'",
        "summary='Review newly discovered CoSources, classify roles/status, and mark attachment gaps.'",
        "next='await_claim'",
        "},",
        "id='TASK_DEFINE_COSOURCE_ROUTING_POLICY'",
        "summary='Define preferred write/read/mirror/control behavior per provider/account.'",
        "id='TASK_HEADLESS_NODE_ONBOARDING'",
        "summary='Prepare clean browser/account nodes for bounded coprocessor participation.'",
        "$tasking = [ordered]@{",
        "scope='COSOURCENET_TASKING'",
        "intended_roles=@(",
        "@{ target='CoUS.4.260324.audit.cont'; role='PRIMARY_ORCHESTRATOR'; action='classify_and_route_new_sources' },",
        "@{ target='CoUS.4.260325s'; role='SHADOW_MONITOR'; action='validate_no_secret_leakage_in_registry' },",
        "@{ target='ALL_ACTIVE_COPROCESSORS'; role='SESSION_COPROCESSOR'; action='propose provider-specific onboarding or policy deltas' }",
        "next='claim_gated_pickup'",
        "$registryRaw = Set-CoExArtifact -Path \"docs/cluster/cosourcenet/COSOURCENET_REGISTRY__LATEST.json\" -Object $registry -Message \"CoEx: COSOURCENET_REGISTRY ($Utc)\"",
        "$inboxRaw    = Set-CoExArtifact -Path \"docs/cluster/cosourcenet/COSOURCENET_INBOX__LATEST.json\"    -Object $inbox    -Message \"CoEx: COSOURCENET_INBOX ($Utc)\"",
        "$taskingRaw  = Set-CoExArtifact -Path \"docs/cluster/cosourcenet/COSOURCENET_TASKING__LATEST.json\"  -Object $tasking  -Message \"CoEx: COSOURCENET_TASKING ($Utc)\"",
        "Write-Host \"COEX_OK -> $registryRaw\"",
        "Write-Host \"COEX_OK -> $inboxRaw\"",
        "Write-Host \"COEX_OK -> $taskingRaw\"",
        "Write-Host \"ENTRIES -> $(@($normalized).Count)\""
      ],
      "sensitivity": "S1"
    }
  ]
}
